# Source this before invoking any reproduction/scripts/shell/* wrapper on the
# local backend (WSL2 Ubuntu + RTX 3090).
#
#   source reproduction/scripts/env/local.env
#
# Idempotent — re-sourcing only refreshes exports.

export REPRO_SYSTEM=local
export REPRO_ROOT="${REPRO_ROOT:-$HOME/repro-track}"
export EMLLM_ROOT="$REPRO_ROOT/em-llm-model"
# Sibling InfLLM checkout used as paper Table 2's baseline. See
# docs/infllm_setup.md for how to populate it. The dir may not exist yet —
# the InfLLM wrappers (06/07_run_infllm_*.sh) check before running.
export INFLLM_ROOT="$REPRO_ROOT/infllm-model"

# HuggingFace cache and offload scratch live in $HOME on local since there is
# no separate $SCRATCH partition. Fits inside the WSL ext4 filesystem.
export HF_HOME="${HF_HOME:-$HOME/.cache/huggingface}"
export TRANSFORMERS_CACHE="$HF_HOME/hub"
export EMLLM_OFFLOAD_DIR="${EMLLM_OFFLOAD_DIR:-/tmp/emllm_offload}"
mkdir -p "$EMLLM_OFFLOAD_DIR" "$HF_HOME"

# Per-system results sink — wrappers write here.
export RESULTS_ROOT="$REPRO_ROOT/reproduction/results/$REPRO_SYSTEM"
mkdir -p "$RESULTS_ROOT"

# Conda — assumes anaconda or miniconda is on PATH already.
if [ -z "${CONDA_DEFAULT_ENV:-}" ]; then
    # Don't auto-activate; the wrappers do it explicitly so failures are loud.
    :
fi

# Avoid PyTorch CUDA fragmentation on long-context allocations.
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

echo "[local.env] REPRO_ROOT=$REPRO_ROOT"
echo "[local.env] HF_HOME=$HF_HOME"
echo "[local.env] EMLLM_OFFLOAD_DIR=$EMLLM_OFFLOAD_DIR"
