# Source this before invoking any reproduction/scripts/shell/* wrapper on
# ASAX (Alabama Supercomputer). Login nodes have outbound internet (for HF
# download); compute nodes do not — the wrappers flip offline mode on the
# latter automatically.
#
#   source reproduction/scripts/env/asax.env
#
# Idempotent — re-sourcing only refreshes exports.

export REPRO_SYSTEM=asax

# --- modules -----------------------------------------------------------------
# ASAX exposes modules through a dynamic profile rather than the default
# Lmod path. Load it first, otherwise `module` is undefined in fresh shells.
# Names below mirror what currently works on Asax (confirmed from a recent
# `run_tft.sh`). If `module load` errors out after a maintenance window,
# run `module avail anaconda cuda` and adjust the versions here.
source /apps/profiles/modules_asax.sh.dyn

module load anaconda/3-2025.12
module load cuda/11.8.0

# --- paths -------------------------------------------------------------------
# ASA's asax cluster doesn't provision a per-user /scratch/<user> directory;
# instead each account gets a generous home (100 GB hard quota). So both
# code and persistent data live under $HOME. Per-job transient state goes
# to /scratch-local (per-compute-node ephemeral, auto-cleaned between jobs).
# Override either path if your account is set up differently.
export REPRO_ROOT="${REPRO_ROOT:-$HOME/repro-track}"
export EMLLM_ROOT="$REPRO_ROOT/em-llm-model"
# Sibling InfLLM checkout used as paper Table 2's baseline. See
# docs/infllm_setup.md for how to populate it. The dir may not exist yet —
# the InfLLM wrappers (06/07_run_infllm_*.sh) check before running.
export INFLLM_ROOT="$REPRO_ROOT/infllm-model"

# HF cache in home so compute-node jobs (with TRANSFORMERS_OFFLINE=1) can
# read pre-downloaded weights. Costs ~14 GB per 7-8B model, so be selective
# about MODELS in 00b_login_node_prep.sh to stay under quota.
export HF_HOME="${HF_HOME:-$HOME/.cache/huggingface}"
export TRANSFORMERS_CACHE="$HF_HOME/hub"

# Per-job offload: /scratch-local exists per compute node and is wiped
# between jobs, perfect for the 100-300 GB transient offload that PassKey
# runs produce. JOB_ID falls back to "login" so login-node setup steps
# get a stable path.
JOB_ID="${SLURM_JOB_ID:-${PBS_JOBID:-login}}"
export EMLLM_OFFLOAD_DIR="${EMLLM_OFFLOAD_DIR:-/scratch-local/emllm_offload_${USER}_${JOB_ID}}"
mkdir -p "$EMLLM_OFFLOAD_DIR" "$HF_HOME"

export RESULTS_ROOT="$REPRO_ROOT/reproduction/results/$REPRO_SYSTEM"
mkdir -p "$RESULTS_ROOT"

# Avoid PyTorch CUDA fragmentation on long-context allocations.
export PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True

# Compute nodes shouldn't try to dial out for HF. Either scheduler id == on a
# compute node under run_script.
if [ -n "${SLURM_JOB_ID:-}${PBS_JOBID:-}" ]; then
    export TRANSFORMERS_OFFLINE=1
    export HF_DATASETS_OFFLINE=1
fi

echo "[asax.env] REPRO_ROOT=$REPRO_ROOT"
echo "[asax.env] HF_HOME=$HF_HOME"
echo "[asax.env] EMLLM_OFFLOAD_DIR=$EMLLM_OFFLOAD_DIR"
echo "[asax.env] JOB_ID=$JOB_ID"
